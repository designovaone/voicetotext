# Copy to .env.local and fill in real values. Never commit .env.local.

# Neon Postgres pooled connection string
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require&channel_binding=require

# Passphrase required on /api/unlock — sets 24h httpOnly cookie
UNLOCK_PHRASE=change-me

# OpenRouter API key — used for both Gemini Flash (transcription) and Haiku 4.5 (transform)
OPENROUTER_API_KEY=sk-or-v1-...
